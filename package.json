{
  "name": "@shop/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start:all": "nx run-many -t serve dev -p api admin shop --parallel=3",
    "format:check": "nx format:check",
    "format:write": "nx format:write",
    "lint": "nx run-many -t lint",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test --coverage",
    "ci:check": "npm run format:check && npm run lint && npm run build && npm run test",
    "typeorm": "ts-node --project tsconfig.base.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate -d apps/api/src/typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d apps/api/src/typeorm.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d apps/api/src/typeorm.config.ts",
    "seed": "ts-node --project apps/api/tsconfig.app.json -r tsconfig-paths/register apps/api/src/app/core/db/seeders/seed.ts"
  },
  "private": true,
  "imports": {
    "#admin-tailwind": "./apps/admin/src/tailwind.css"
  },
